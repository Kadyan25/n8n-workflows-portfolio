    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO vector_chunks\n  (model_id, scope, brand_id, drive_file_id, chunk_id_in_file, text_preview, vector_id)\nVALUES\n  (\n    NULL,\n    '{{ $(\"Code in JavaScript\").item.json.scope }}',\n    NULL,\n    '{{ $(\"Download file\").item.json.id }}',\n    {{ $(\"Code in JavaScript\").item.json.chunk_id_in_file }},\n    '{{ $(\"Code in JavaScript\").item.json.text_preview.replace(/'/g, \"''\") }}',\n    '{{ $(\"Download file\").item.json.id }}-{{ $(\"Code in JavaScript\").item.json.chunk_id_in_file }}'\n  )\nON DUPLICATE KEY UPDATE\n  text_preview = VALUES(text_preview),\n  vector_id = VALUES(vector_id);",
        "options": {}
