        "jsonBody": "{\n  \"model\": \"models/gemini-embedding-001\",\n  \"content\": {\n    \"parts\": [\n      {\n        \"text\": \"{{$json['chunk_text']}}\"\n      }\n    ]\n  }\n}",
        "options": {}
