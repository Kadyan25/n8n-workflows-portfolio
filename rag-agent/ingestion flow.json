    {
      "parameters": {
        "jsCode": "const text = $json[\"data\"] || $json[\"text\"] || \"\";\nconst maxChunks = 8;\nif (!text) {\n  return [];\n}\n\nconst chunkSize = Math.ceil(text.length / maxChunks);\nconst chunks = [];\n\nfor (let i = 0; i < maxChunks; i++) {\n  const start = i * chunkSize;\n  if (start >= text.length) break;\n\n  const end = Math.min(start + chunkSize, text.length);\n  const chunkText = text.slice(start, end);\n\n  // Preview (short)\n  const rawPreview = chunkText.slice(0, 180);\n  const safePreview = rawPreview\n    .replace(/\\r/g, \" \")\n    .replace(/\\n/g, \" \")\n    .replace(/\"/g, '\\\\\"');\n\n  // Full chunk text – safe for JSON\n  const safeChunkText = chunkText\n    .replace(/\\r/g, \" \")      // carriage return → space\n    .replace(/\\n/g, \" \")      // newline → space\n    .replace(/\"/g, '\\\\\"');    // quotes escape\n\n  chunks.push({\n    json: {\n      chunk_text: safeChunkText,     // sanitized full text\n      text_preview: safePreview,\n      scope: 'model',\n      brand: 'Tesla',\n      model_name: 'Model 3',\n      drive_file_id: $json[\"id\"],\n      chunk_id_in_file: i\n    }\n  });\n}\n\nreturn chunks;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "f87c52cc-dfe7-42d7-9c69-477e9f5b60fe",
