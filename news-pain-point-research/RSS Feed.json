      ],
      "id": "b109bcfd-8331-4d37-907c-06c050d2de80",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=\"From the provided news articles, identify and extract the most painful issues faced by clients specifically related to {{ $json.formData[0].subject }}. Focus on problems that cause significant distress, challenges, or dissatisfaction among clients within this domain. Summarize the top issue with supporting evidence from the articles, including affected client groups, the nature of their pain, and relevant quotes or data. Present the findings in a clear and structured manner.\"\n\n{{ $json.links }}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        -1408,
        -192
      ],
      "id": "055e5ac5-36c8-4768-b43a-129215a911ce",
      "name": "AI Agent"
    },
