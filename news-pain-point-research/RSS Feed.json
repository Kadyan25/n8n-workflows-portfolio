    {
      "parameters": {
        "jsCode": "const limit = $node[\"On form submission\"].json[\"LookBack Period\"];\nitems = items.slice(0, limit);\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
