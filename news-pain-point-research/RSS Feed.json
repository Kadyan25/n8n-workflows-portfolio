        -16
      ],
      "id": "867f4012-a0e4-4fc3-b549-534ddb75d107",
      "name": "Google Gemini Chat Model"
    },
    {
      "parameters": {
        "jsCode": "// Extract the first item (form input data)\nconst formData = items[0].json;\n\n// Extract links from remaining items (RSS feed results)\nconst links = [];\nitems.slice(1).forEach(item => {\n  if (item.json.link) {\n    links.push(item.json.link);\n  }\n});\n\n// Create the two arrays\nconst formDataArray = [{\n  url: formData.url,\n  lookbackPeriod: formData[\"LookBack Period\"],\n  postMessage: formData[\"Post Message for Linkedin\"],\n  subject: formData[\"Subject for research\"]\n}];\n\nconst linksArray = links;\n\n// Return as a single item with both arrays\nreturn [{\n  json: {\n    formData: formDataArray,\n    links: linksArray\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1712,
        -192
      ],
      "id": "cf4e2529-7e18-4d55-ae58-6fd2d0c47732",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        -2176,
        -192
      ],
      "id": "380ce0c3-9568-4fde-b731-2a879e3a3820",
      "name": "Merge"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=\"Using the insights from the previous analysis prompt ({{ $json.output }}) about the most significant and painful issue currently faced by clients, \ncreate a complete marketing concept for a 5-slide LinkedIn carousel post.\n\nDefine:\n\nThe core concept and angle of the carousel, clearly tied to the identified client pain point.\n\nThe Ideal Customer Profile (ICP), including industry/role, company size, main goals, and main frustrations.\n\nThe primary objective of the carousel (e.g., demand generation, lead nurture, authority building, or event/promo).\n\nFor each of the 5 slides, provide:\n\nSlide number and purpose in the narrative (hook, problem, insight, solution, CTA, etc.).\n\nExact, concise headline text (max ~10–12 words).\n\n1–2 short bullet points or a single short paragraph for body text.\n\nClear art direction for the image: describe the visual concept, style (e.g., minimalist, corporate, illustration, photo-based), suggested colors, and any key elements/objects or characters that should appear so a designer or image-generation AI can create the image.\n\nOptimize specifically for LinkedIn:\n\nEnsure the messaging is professional, pain-point-driven, and emotionally resonant while staying credible.\n\nMake sure each slide works as a standalone visual but also tells a coherent story when viewed in sequence.\n\nEnd slide 5 with a strong, specific call-to-action relevant to the ICP.\n\nOutput everything in a structured format, grouped by: 'Concept Overview', 'ICP', and 'Slides 1–5 (Copy + Image Brief)' so it can be handed directly to an image-generation and design workflow.\"",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        -896,
        -192
      ],
      "id": "49234e8a-b97b-4a58-9177-baac211cf48c",
